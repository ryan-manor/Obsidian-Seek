{
    "name": "seek",
    "version": "1.0.0",
    "description": "Obsidian plugin for on-device hybrid semantic and lexical vault search.",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "node esbuild.config.mjs production",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "version": "node version-bump.mjs && git add manifest.json versions.json"
    },
    "keywords": [
        "obsidian",
        "semantic-search",
        "embeddings",
        "transformers.js"
    ],
    "author": "Ryan Manor",
    "license": "MIT",
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^22.0.0",
        "esbuild": "^0.24.0",
        "fake-indexeddb": "^6.2.5",
        "js-yaml": "^4.2.0",
        "obsidian": "^1.7.2",
        "typescript": "^5.6.0",
        "vitest": "^2.1.0"
    },
    "dependencies": {
        "minisearch": "^7.2.0"
    }
}
