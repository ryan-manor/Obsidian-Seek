{
    "compilerOptions": {
        "baseUrl": ".",
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES2022",
        "allowImportingTsExtensions": true,
        "moduleResolution": "bundler",
        "importHelpers": true,
        "isolatedModules": true,
        "strictNullChecks": true,
        "noImplicitAny": true,
        "noUnusedLocals": false,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "lib": [
            "ES2022",
            "DOM"
        ]
    },
    "include": [
        "src/**/*.ts"
    ]
}
