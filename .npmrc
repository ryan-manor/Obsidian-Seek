# Obsidian installs a plugin from the GitHub Release whose tag EXACTLY matches
# manifest.json "version" — with NO leading "v". npm's default version tag-prefix
# is "v", which would tag 1.0.0 as "v1.0.0" and break install/BRAT discovery.
# Empty the prefix so `npm version 1.0.0` tags "1.0.0", as the release workflow expects.
tag-version-prefix=""
